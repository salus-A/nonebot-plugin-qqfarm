# ========== QQ农场插件配置 ==========
# 注意：所有插件配置必须使用前缀 NONEBOT_PLUGIN_QQFARM_

# ---------- 必填配置 ----------
# QQ农场后端 API 基础 URL（例如：https://your-domain.com 或 http://127.0.0.1:8080）
NONEBOT_PLUGIN_QQFARM_BASE_URL=https://your-domain.com

# 后端管理员密码（与后端配置一致）
NONEBOT_PLUGIN_QQFARM_ADMIN_PASSWORD=your_admin_password

# 数据库配置（使用双下划线嵌套，NoneBot 会自动解析为字典）
# 数据库主机
NONEBOT_PLUGIN_QQFARM_DATABASE__HOST=localhost
# 数据库端口
NONEBOT_PLUGIN_QQFARM_DATABASE__PORT=3306
# 数据库用户名
NONEBOT_PLUGIN_QQFARM_DATABASE__USER=qq_farm_user
# 数据库密码
NONEBOT_PLUGIN_QQFARM_DATABASE__PASSWORD=your_db_password
# 数据库名
NONEBOT_PLUGIN_QQFARM_DATABASE__DATABASE=qq_farm_bot
# 数据库字符集（可选，默认 utf8mb4）
NONEBOT_PLUGIN_QQFARM_DATABASE__CHARSET=utf8mb4


# 外部 API 密钥（如果后端启用了外部 API 认证）
NONEBOT_PLUGIN_QQFARM_API_KEY=

# HTTP 请求超时时间（秒）
NONEBOT_PLUGIN_QQFARM_TIMEOUT=30

# 离线检查间隔（秒），后台自动检测离线账号并通知
NONEBOT_PLUGIN_QQFARM_OFFLINE_CHECK_INTERVAL=60

# 初始管理员 QQ 号列表（JSON 数组格式）
NONEBOT_PLUGIN_QQFARM_ADMIN_QQ=[123456789]

# 默认推送的群号（支持单个数字、逗号分隔字符串或列表）
# 示例：1060330308 或 "1060330308,1084498190" 或 [1060330308,1084498190]
NONEBOT_PLUGIN_QQFARM_DEFAULT_GROUP=1060330308,1084498190

# Webhook 服务公网地址（用于提示用户，实际路由由 NoneBot 自动处理）
NONEBOT_PLUGIN_QQFARM_WEBHOOK_URL=https://webhook.your-domain.com

# ---------- Redis 配置（可选，用于缓存等）----------
# Redis 主机
NONEBOT_PLUGIN_QQFARM_REDIS__HOST=localhost
# Redis 端口
NONEBOT_PLUGIN_QQFARM_REDIS__PORT=6379
# Redis 密码（无密码则留空）
NONEBOT_PLUGIN_QQFARM_REDIS__PASSWORD=